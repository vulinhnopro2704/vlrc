{
  "name": "@platform-core/hooks",
  "version": "0.0.0",
  "description": "Reusable PlatformCore React hooks.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
