    "build": "tsc -p tsconfig.json && vite build",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.3",
    "vite": "8.0.14"
  },
  "publishConfig": {
    "access": "public"
  }
}
