{
  "files": [],
  "references": [{ "path": "./tsconfig.app.json" }, { "path": "./tsconfig.node.json" }],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./src/assets/*"],
      "@components/*": ["./src/components/*"],
      "@constants/*": ["./src/constants/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@routes/*": ["./src/routes/*"],
      "@stores/*": ["./src/stores/*"],
      "@utils/*": ["./src/utils/*"],
      "@lib/*": ["./src/lib/*"],
      "@api/*": ["./src/api/*"],
      "@types/*": ["./src/types/*"],
      "@shared/*": ["./src/shared/*"],
      "@platform-core/components": ["./packages/components/src/index.ts"],
      "@platform-core/components/*": ["./packages/components/src/*"],
      "@platform-core/hooks": ["./packages/hooks/src/index.ts"]
    }
  }
}
